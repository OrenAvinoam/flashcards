# --- Shared ---
JWT_SECRET=change-me-to-a-long-random-string
LOG_LEVEL=INFO
OTEL_ENDPOINT=http://otel-collector:4317

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=flashcards
POSTGRES_USER=flashcards
POSTGRES_PASSWORD=flashcards

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- auth-svc ---
AUTH_DATABASE_URL=postgresql+asyncpg://flashcards:flashcards@postgres:5432/flashcards?options=-csearch_path%3Dauth

# --- deck-svc ---
DECK_DATABASE_URL=postgresql+asyncpg://flashcards:flashcards@postgres:5432/flashcards?options=-csearch_path%3Ddeck

# --- scheduler-svc ---
DECK_SVC_URL=http://deck-svc:8002

# --- generation-svc ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- web ---
AUTH_SVC_URL=http://auth-svc:8001
WEB_DECK_SVC_URL=http://deck-svc:8002
WEB_SCHEDULER_SVC_URL=http://scheduler-svc:8003
WEB_GENERATION_SVC_URL=http://generation-svc:8004
SESSION_SECRET=change-me-to-a-long-random-string

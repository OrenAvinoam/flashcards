# Copy to .env for local (non-Docker) development.
# Postgres + Redis still run in Docker: docker compose up postgres redis -d

JWT_SECRET=local-dev-secret-change-me
LOG_LEVEL=INFO
OTEL_ENDPOINT=http://localhost:4317

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flashcards
POSTGRES_USER=flashcards
POSTGRES_PASSWORD=flashcards

REDIS_URL=redis://localhost:6379

AUTH_DATABASE_URL=postgresql+asyncpg://flashcards:flashcards@localhost:5432/flashcards?options=-csearch_path%3Dauth
DECK_DATABASE_URL=postgresql+asyncpg://flashcards:flashcards@localhost:5432/flashcards?options=-csearch_path%3Ddeck

DECK_SVC_URL=http://localhost:8002

LLM_PROVIDER=gemini
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

AUTH_SVC_URL=http://localhost:8001
WEB_DECK_SVC_URL=http://localhost:8002
WEB_SCHEDULER_SVC_URL=http://localhost:8003
WEB_GENERATION_SVC_URL=http://localhost:8004
SESSION_SECRET=local-dev-session-secret
